<package xmlns="http://www.idpf.org/2007/opf" xmlns:epub="http://www.idpf.org/2007/ops" version="3.0" unique-identifier="isbn-id" xml:lang="en" prefix="calibre: https://calibre-ebook.com">
  <metadata xmlns:dc="http://purl.org/dc/elements/1.1/">
    <dc:title id="t1">The Bitcoin Standard: The Decentralized Alternative to Central Banking</dc:title>
    <dc:creator id="id">Ammous, Saifedean</dc:creator>
    <dc:source id="src-id">urn:isbn:9781119473862</dc:source>
    <dc:identifier>amazon:1119473861</dc:identifier>
    <dc:identifier>google:Sw5TDwAAQBAJ</dc:identifier>
